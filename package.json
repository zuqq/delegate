{
	"name": "delegate",
	"version": "0.1.0",
	"description": "Pi extension: delegate tasks to specialized subagents with isolated context windows.",
	"keywords": [
		"pi-package",
		"pi-extension",
		"subagent",
		"delegate"
	],
	"license": "MIT",
	"author": "zuqq <noahheld17@gmail.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/zuqq/delegate.git"
	},
	"bugs": {
		"url": "https://github.com/zuqq/delegate/issues"
	},
	"homepage": "https://github.com/zuqq/delegate#readme",
	"type": "module",
	"private": true,
	"files": [
		"src",
		"README.md",
		"LICENSE"
	],
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"scripts": {
		"check": "biome check --error-on-warnings .",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"test": "vitest --run",
		"test:watch": "vitest"
	},
	"peerDependencies": {
		"@earendil-works/pi-agent-core": "*",
		"@earendil-works/pi-ai": "*",
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*",
		"typebox": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.5",
		"@earendil-works/pi-agent-core": "0.79.10",
		"@earendil-works/pi-ai": "0.79.10",
		"@earendil-works/pi-coding-agent": "0.79.10",
		"@earendil-works/pi-tui": "0.79.10",
		"@types/node": "24.13.2",
		"typebox": "1.1.38",
		"typescript": "5.9.3",
		"vitest": "3.2.6"
	}
}
